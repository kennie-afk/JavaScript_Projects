{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": ".",

    "paths": {
      "@models": ["src/models/index"],
      "@models/*": ["src/models/*"],

      "@config/*": ["src/config/*"],
      "@auth/*": ["src/auth/*"],

      "@users/*": ["src/users/*"],
      "@families/*": ["src/families/*"],
      "@members/*": ["src/members/*"],
      "@events/*": ["src/events/*"],
      "@announcements/*": ["src/announcements/*"],
      "@sermons/*": ["src/sermons/*"],
      "@contributions/*": ["src/contributions/*"],
      "@attendance/*": ["src/attendance/*"],
      "@ministries/*": ["src/ministries/*"],
      "@small_groups/*": ["src/small_groups/*"]
    },

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "typeRoots": ["./node_modules/@types", "./src/types"]
  },

  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}